# Copy this to .env.development.local for local dev

# Dev API server. Use a full URL when the API runs on a different origin (CORS required).
# Defaults to /api (relative — assumes a dev proxy or same-origin server).
# VITE_API_BASE=http://localhost:3000/api

# Default H5 base URL (used as fallback if /oem/config doesn't return one).
# VITE_H5_BASE_URL=https://h5.wonderbear.app
