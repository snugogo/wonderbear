# WonderBear v7 家长 H5 - 开发环境
VITE_APP_TITLE=WonderBear
VITE_API_BASE_URL=http://localhost:3000
VITE_API_PREFIX=/api

# mock 开关:true 时 axios 走本地 mock 数据,不发真实请求
# 已对接真实服务端(批次 2 auth + 批次 3 device/child/parent),关闭 mock 走真请求
VITE_USE_MOCK=false

# 默认语言(浏览器未匹配时兜底)
VITE_DEFAULT_LOCALE=zh

# dev server 端口(跟 HANDOFF 文档一致)
VITE_DEV_PORT=5174
