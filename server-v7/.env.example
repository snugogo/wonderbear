# ============================================================
# WonderBear server-v7 .env example
# Copy to .env and fill in actual values. NEVER commit .env.
# ============================================================

# ----- [infra] 启动必需,缺了服务起不来 -----
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://wonderbear:wonderbear123@localhost:5432/wonderbear_db
REDIS_URL=redis://localhost:6379
# 生产环境必须是 32 字节以上的随机字符串,dev 用默认值即可
# openssl rand -hex 32 生成
JWT_SECRET=dev_jwt_secret_change_me_in_prod_at_least_32_bytes_long


# ----- [mail] Resend 邮件验证码 / 批次 2 用 -----
# 申请:resend.com → API Keys
RESEND_API_KEY=
# 发件人,需先在 Resend 验证域名
MAIL_FROM=noreply@wonderbear.app
MAIL_FROM_NAME=WonderBear


# ----- [ai] LLM + 三路生图 / 批次 4 用 -----
# OpenAI:生图主通道(DALL-E 3)+ LLM 备选
# 申请:platform.openai.com → API keys
OPENAI_API_KEY=

# Gemini:LLM 主通道 + 生图二路(Imagen 3)
# 申请:aistudio.google.com → Get API Key
GEMINI_API_KEY=

# FAL:生图三路降级(flux-schnell)
# 申请:fal.ai → API Keys
FAL_KEY=


# ----- [tts] ElevenLabs / 批次 4 用 -----
# 申请:elevenlabs.io → Settings → API Keys
ELEVENLABS_API_KEY=
# 各语言的 voice_id,到 elevenlabs.io → VoiceLab 选
VOICE_ID_EN=
VOICE_ID_PL=
VOICE_ID_RO=
VOICE_ID_ES=
VOICE_ID_FR=
VOICE_ID_ZH=


# ----- [speech] Google Cloud Speech-to-Text / 批次 4 用 -----
# 申请:console.cloud.google.com → APIs → Speech-to-Text → 创建 API key
# 或用 service account JSON(更推荐,配置 GOOGLE_APPLICATION_CREDENTIALS 路径)
GOOGLE_SPEECH_KEY=
GOOGLE_APPLICATION_CREDENTIALS=


# ----- [stripe] 订阅支付主通道 / 批次 5 用 -----
# 香港 entity dashboard:dashboard.stripe.com
# Test keys 以 sk_test_ 开头,生产 sk_live_
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs 在 Stripe Dashboard → Products 建好后填
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=


# ----- [paypal] PayPal 订阅 / 批次 5 用 -----
# 申请:developer.paypal.com → My Apps & Credentials
# Sandbox 和 Live 分别两组
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# 'sandbox' or 'live'
PAYPAL_MODE=sandbox
# PayPal plan IDs
PAYPAL_PLAN_ID_MONTHLY=
PAYPAL_PLAN_ID_YEARLY=


# ----- [storage] Cloudflare R2 / media persistence -----
# Apply: dash.cloudflare.com → R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=wonderbear-images
# S3-compat endpoint. Format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=
# R2 public domain — turn on in Bucket Settings → Public Access.
# Either a custom domain or the Cloudflare-issued pub-xxxxx.r2.dev URL.
R2_PUBLIC_URL=

# Local-dev only: switch storage backend
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage


# ----- [debug] /debug/gallery basic-auth password -----
# Empty = /debug/* routes are NOT registered (safe default for prod).
# Set any string ≥8 chars to enable. Username can be anything; password must match.
DEBUG_GALLERY_PASSWORD=


# ----- 非 key 配置项 -----
# 图片风格后缀(注入到所有生图 prompt 末尾,保持风格一致)
IMAGE_STYLE_SUFFIX=
# 首页封面图的固定构图提示
IMAGE_PAGE1_COMPOSITION=
